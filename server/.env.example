PORT=5004

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dbt_analytics
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# NestJS / TypeORM connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dbt_analytics

# Auth (httpOnly JWT cookie)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5001
NODE_ENV=development
LOG_LEVEL=debug
API_VERSION=v1

# Seed profiles: demo | large | mega
SEED_PROFILE=large
SEED_INCREMENTAL=true
SEED_BATCH_SIZE=1000
